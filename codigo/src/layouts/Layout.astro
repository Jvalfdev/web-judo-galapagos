---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import IntroSplash from "../components/site/IntroSplash.astro";
import logoSplash from "../assets/logo mas detallago.jpg";
import ScrollOrchestra from "../components/site/ScrollOrchestra.astro";
import WhatsAppFloat from "../components/site/WhatsAppFloat.astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Club de Judo Galápagos",
	description =
		"Club de judo en Galápagos (Guadalajara): horarios, noticias, calendario e información del club.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />
		<script is:inline>
			try {
				if (localStorage.getItem("jg-theme") === "dark") {
					document.documentElement.setAttribute("data-theme", "dark");
				}
			} catch (e) {}
			try {
				if (sessionStorage.getItem("jg-splash-seen") === "1") {
					document.documentElement.classList.add("jg-no-splash");
				}
			} catch (e) {}
		</script>
	</head>
	<body>
		<IntroSplash logoSrc={logoSplash.src} />
		<a class="skip-link" href="#contenido-principal">Saltar al contenido</a>
		<slot />
		<WhatsAppFloat />
		<ScrollOrchestra />
		<script is:inline>
			(function () {
				if (window.__jgThemeBound) return;
				window.__jgThemeBound = true;

				function syncThemeToggleUi() {
					var btn = document.querySelector("[data-theme-toggle]");
					if (!btn) return;
					var dark = document.documentElement.getAttribute("data-theme") === "dark";
					btn.setAttribute("aria-label", dark ? "Activar modo claro" : "Activar modo oscuro");
					btn.setAttribute("title", dark ? "Modo claro" : "Modo oscuro");
				}

				document.addEventListener(
					"click",
					function (e) {
						var target = e.target;
						if (!(target instanceof Element)) return;
						var btn = target.closest("[data-theme-toggle]");
						if (!btn) return;
						e.preventDefault();
						var html = document.documentElement;
						if (html.getAttribute("data-theme") === "dark") {
							html.removeAttribute("data-theme");
							try {
								localStorage.setItem("jg-theme", "light");
							} catch (err) {}
						} else {
							html.setAttribute("data-theme", "dark");
							try {
								localStorage.setItem("jg-theme", "dark");
							} catch (err) {}
						}
						syncThemeToggleUi();
					},
					true,
				);

				document.addEventListener("astro:page-load", syncThemeToggleUi);
				syncThemeToggleUi();
			})();
		</script>
	</body>
</html>
