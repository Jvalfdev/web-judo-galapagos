---
import Layout from "../layouts/Layout.astro";
import Header from "../components/site/Header.astro";
import Hero from "../components/site/Hero.astro";
import LatestNews from "../components/site/LatestNews.astro";
import Schedule from "../components/site/Schedule.astro";
import Footer from "../components/site/Footer.astro";
---

<Layout
	title="Escuela de Judo Galápagos"
	description="Escuela de Judo Galápagos (Galápagos, Guadalajara): horarios, noticias, calendario y datos de contacto."
>
	<Header />
	<main id="contenido-principal" tabindex="-1" class="home-main">
		<Hero />
		<div class="home-scroll-layer">
			<LatestNews />
			<Schedule />
		</div>
	</main>
	<div class="home-scroll-layer">
		<Footer />
	</div>
</Layout>

<style>
	.home-scroll-layer {
		position: relative;
		z-index: 2;
	}
</style>
