---
import PageLayout from "../../layouts/PageLayout.astro";
import { Image } from "astro:assets";
import { etiquetaTipoNoticia, noticias } from "../../data/noticias";
import imgEntregaCinturon from "../../assets/entrega-cinturon.jpg";

const sorted = [...noticias].sort((a, b) => b.date.localeCompare(a.date));

function formatDate(iso: string) {
	return new Date(iso + "T12:00:00").toLocaleDateString("es-EC", {
		day: "numeric",
		month: "long",
		year: "numeric",
	});
}
---

<PageLayout
	title="Noticias"
	description="Noticias y avisos del Club de Judo Galápagos — competiciones, exámenes y vida del club."
>
	<div class="page-shell page-shell--wide">
		<header class="page-hero">
			<p class="page-hero__eyebrow">Actualidad</p>
			<h1 class="page-hero__title">Noticias</h1>
			<p class="page-hero__lead">
				Comunicados del tatami: convocatorias, exámenes y mensajes del club. En la portada se muestran
				las mismas entradas en formato resumido.
			</p>
		</header>

		<ul class="news-archive">
			{
				sorted.map((n) => (
					<li class="news-archive__item">
						<a href={`/noticias/${n.slug}`} class="news-archive__link">
							<Image
								src={imgEntregaCinturon}
								alt="Ceremonia de entrega de cinturón del club"
								class="news-archive__thumb"
								width={280}
								height={187}
								sizes="176px"
								loading="lazy"
								decoding="async"
							/>
							<div class="news-archive__body">
								<time class="news-archive__date" datetime={n.date}>
									{formatDate(n.date)}
								</time>
								<span class="news-archive__tag">{etiquetaTipoNoticia(n.tipoNoticia)}</span>
								<h2 class="news-archive__title">{n.title}</h2>
								<p class="news-archive__excerpt">{n.excerpt}</p>
							</div>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</PageLayout>

<style>
	.news-archive {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.news-archive__link {
		display: grid;
		grid-template-columns: minmax(0, 11rem) 1fr;
		gap: var(--space-md);
		align-items: start;
		padding: var(--space-md);
		border-radius: var(--radius-lg);
		border: 1px solid var(--card-border);
		background: var(--card-surface);
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.25s ease,
			background 0.25s ease;
	}

	.news-archive__thumb {
		display: block;
		width: 100%;
		height: auto;
		border-radius: var(--radius-md);
		object-fit: cover;
		aspect-ratio: 4 / 3;
		border: 1px solid var(--border-subtle);
	}

	.news-archive__body {
		min-width: 0;
	}

	.news-archive__link:hover {
		border-color: var(--border-subtle);
		background: var(--card-surface-hover);
	}

	.news-archive__date {
		display: block;
		margin-bottom: 0.35rem;
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--accent);
		font-variant-numeric: tabular-nums;
	}

	.news-archive__tag {
		display: inline-block;
		margin-bottom: 0.45rem;
		padding: 0.2rem 0.5rem;
		border-radius: var(--radius-full);
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.055em;
		text-transform: uppercase;
		color: var(--text);
		background: var(--accent-soft);
		border: 1px solid var(--footer-border-accent);
	}

	.news-archive__title {
		margin: 0 0 0.35rem;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 1.15rem;
		line-height: 1.25;
		letter-spacing: -0.02em;
	}

	.news-archive__excerpt {
		margin: 0;
		font-size: 0.94rem;
		color: var(--text-muted);
		line-height: 1.52;
	}
</style>
