---
import type { EntradaCalendario, TipoCalendario } from "../../data/calendario";
import { etiquetaTipo } from "../../data/calendario";

interface Props {
	items: EntradaCalendario[];
}

const { items } = Astro.props;

const tipoLabels: Record<TipoCalendario, string> = {
	competicion: etiquetaTipo("competicion"),
	examen: etiquetaTipo("examen"),
	evento: etiquetaTipo("evento"),
	club: etiquetaTipo("club"),
};

const calendarItemsJson = JSON.stringify(items);
const calendarTipoLabelsJson = JSON.stringify(tipoLabels);
---

<div class="club-cal" data-club-cal>
	<div class="club-cal__surface">
		<div class="club-cal__toolbar">
			<div class="club-cal__tabs" role="tablist" aria-label="Vista del calendario">
				<button type="button" class="club-cal__tab" role="tab" aria-selected="true" data-cal-tab="month">
					Mes
				</button>
				<button type="button" class="club-cal__tab" role="tab" aria-selected="false" data-cal-tab="year">
					Año
				</button>
			</div>

			<div class="club-cal__nav club-cal__nav--month" data-cal-nav-month>
				<button type="button" class="club-cal__arrow" aria-label="Mes anterior" data-cal-prev-month>
					‹
				</button>
				<h2 class="club-cal__period" data-cal-month-heading></h2>
				<button type="button" class="club-cal__arrow" aria-label="Mes siguiente" data-cal-next-month>
					›
				</button>
				<button type="button" class="club-cal__today" data-cal-today>Hoy</button>
			</div>

			<div class="club-cal__nav club-cal__nav--year is-hidden" data-cal-nav-year hidden>
				<button type="button" class="club-cal__arrow" aria-label="Año anterior" data-cal-prev-year>
					‹
				</button>
				<h2 class="club-cal__period" data-cal-year-heading></h2>
				<button type="button" class="club-cal__arrow" aria-label="Año siguiente" data-cal-next-year>
					›
				</button>
			</div>
		</div>

		<p class="club-cal__legend">
			<span class="club-cal__legend-item"><i class="club-cal__dot club-cal__dot--competicion"></i> Competición</span>
			<span class="club-cal__legend-item"><i class="club-cal__dot club-cal__dot--examen"></i> Examen</span>
			<span class="club-cal__legend-item"><i class="club-cal__dot club-cal__dot--evento"></i> Evento</span>
			<span class="club-cal__legend-item"><i class="club-cal__dot club-cal__dot--club"></i> Club</span>
		</p>

		<div class="club-cal__panel" data-cal-panel-month>
			<div class="club-cal__month-matrix" data-cal-month-grid></div>
		</div>

		<div class="club-cal__day-sheet" data-cal-day-sheet hidden>
			<div class="club-cal__day-sheet-inner">
				<p class="club-cal__day-sheet-date" data-cal-day-sheet-date></p>
				<p class="club-cal__day-sheet-empty" data-cal-day-sheet-empty hidden>Este día no hay eventos en el calendario.</p>
				<ul class="club-cal__day-sheet-list" data-cal-day-sheet-list></ul>
			</div>
		</div>

		<div class="club-cal__panel is-hidden" data-cal-panel-year hidden>
			<div class="club-cal__year-grid" data-cal-year-grid></div>
		</div>
	</div>

	<section class="club-cal__list-section" aria-labelledby="club-cal-list-title" aria-live="polite">
		<div class="club-cal__list-head">
			<h2 id="club-cal-list-title" class="club-cal__list-title" data-cal-list-title>Eventos</h2>
			<p class="club-cal__list-sub" data-cal-list-sub></p>
		</div>
		<p class="club-cal__empty is-hidden" data-cal-empty>No hay eventos en este periodo.</p>
		<ul class="club-cal__list cal-list" data-cal-list></ul>
	</section>
</div>

<script define:vars={{ calendarItemsJson, calendarTipoLabelsJson }}>
	const items = JSON.parse(calendarItemsJson);
	const tipoLabels = JSON.parse(calendarTipoLabelsJson);
	function pad(n) {
		return String(n).padStart(2, "0");
	}

	function iso(y, m1, d) {
		return `${y}-${pad(m1)}-${pad(d)}`;
	}

	function etiqueta(tipo) {
		return tipoLabels[tipo] ?? tipo;
	}

	function overlapsMonth(e, y, m0) {
		const start = e.fechaInicio;
		const end = e.fechaFin || e.fechaInicio;
		const last = new Date(y, m0 + 1, 0).getDate();
		const monthStart = iso(y, m0 + 1, 1);
		const monthEnd = iso(y, m0 + 1, last);
		return start <= monthEnd && end >= monthStart;
	}

	function overlapsYear(e, y) {
		const start = e.fechaInicio;
		const end = e.fechaFin || e.fechaInicio;
		const yStart = `${y}-01-01`;
		const yEnd = `${y}-12-31`;
		return start <= yEnd && end >= yStart;
	}

	function eachDayOfEvent(e) {
		const days = [];
		const [ya, ma, da] = e.fechaInicio.split("-").map(Number);
		const [yb, mb, db] = (e.fechaFin || e.fechaInicio).split("-").map(Number);
		const cur = new Date(ya, ma - 1, da);
		const end = new Date(yb, mb - 1, db);
		while (cur.getTime() <= end.getTime()) {
			days.push(iso(cur.getFullYear(), cur.getMonth() + 1, cur.getDate()));
			cur.setDate(cur.getDate() + 1);
		}
		return days;
	}

	/** @type {Map<string, Set<string>>} */
	function buildDayTipos(items) {
		const map = new Map();
		for (const e of items) {
			for (const day of eachDayOfEvent(e)) {
				if (!map.has(day)) map.set(day, new Set());
				map.get(day).add(e.tipo);
			}
		}
		return map;
	}

	function buildDayEvents(items) {
		const map = new Map();
		for (const e of items) {
			for (const day of eachDayOfEvent(e)) {
				if (!map.has(day)) map.set(day, []);
				map.get(day).push(e);
			}
		}
		const ordenTipo = { competicion: 0, examen: 1, evento: 2, club: 3 };
		for (const [day, arr] of map) {
			const seen = new Set();
			const uniq = [];
			for (const ev of arr) {
				if (seen.has(ev.id)) continue;
				seen.add(ev.id);
				uniq.push(ev);
			}
			uniq.sort((a, b) => {
				const ta = ordenTipo[a.tipo] ?? 9;
				const tb = ordenTipo[b.tipo] ?? 9;
				if (ta !== tb) return ta - tb;
				return a.fechaInicio.localeCompare(b.fechaInicio) || a.titulo.localeCompare(b.titulo);
			});
			map.set(day, uniq);
		}
		return map;
	}

	function formatRange(e) {
		const opts = { day: "numeric", month: "short" };
		const i = new Date(e.fechaInicio + "T12:00:00").toLocaleDateString("es-EC", opts);
		if (!e.fechaFin) return i;
		const f = new Date(e.fechaFin + "T12:00:00").toLocaleDateString("es-EC", opts);
		return `${i} — ${f}`;
	}

	function monthTitle(y, m0) {
		return new Date(y, m0, 1).toLocaleDateString("es-EC", {
			month: "long",
			year: "numeric",
		});
	}

	function shortMonth(m0) {
		return new Date(2020, m0, 1).toLocaleDateString("es-EC", { month: "short" });
	}

	function pickInitialMonth(items) {
		const now = new Date();
		const y = now.getFullYear();
		const m0 = now.getMonth();
		const inCurrent = items.some((e) => overlapsMonth(e, y, m0));
		if (inCurrent) return { y, m0 };
		if (!items.length) return { y, m0 };
		const sorted = [...items].sort((a, b) => a.fechaInicio.localeCompare(b.fechaInicio));
		const t = sorted.find((e) => e.fechaInicio >= iso(y, m0 + 1, now.getDate())) || sorted[0];
		const [yy, mm] = t.fechaInicio.split("-").map(Number);
		return { y: yy, m0: mm - 1 };
	}

	function formatDayHeading(dayStr) {
		const [yy, mm, dd] = dayStr.split("-").map(Number);
		const dt = new Date(yy, mm - 1, dd);
		const capital = (s) => s.charAt(0).toUpperCase() + s.slice(1);
		return capital(dt.toLocaleDateString("es-EC", { weekday: "long", day: "numeric", month: "long", year: "numeric" }));
	}

	function renderDots(types) {
		const order = ["competicion", "examen", "evento", "club"];
		const frag = document.createDocumentFragment();
		const list = [...types].sort((a, b) => order.indexOf(a) - order.indexOf(b));
		for (const t of list.slice(0, 4)) {
			const i = document.createElement("i");
			i.className = `club-cal__dot club-cal__dot--${t}`;
			frag.appendChild(i);
		}
		return frag;
	}

	function renderMonthGrid(root, dayTipos, y, m0, todayStr) {
		root.replaceChildren();
		const letters = ["L", "M", "X", "J", "V", "S", "D"];
		const names = ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"];
		for (let i = 0; i < 7; i++) {
			const w = document.createElement("div");
			w.className = "club-cal__wk";
			w.textContent = letters[i];
			w.title = names[i];
			w.setAttribute("aria-hidden", "true");
			root.appendChild(w);
		}

		const first = new Date(y, m0, 1);
		const mondayOffset = (first.getDay() + 6) % 7;
		const lastDay = new Date(y, m0 + 1, 0).getDate();

		for (let i = 0; i < mondayOffset; i++) {
			const cell = document.createElement("div");
			cell.className = "club-cal__cell club-cal__cell--pad";
			cell.setAttribute("aria-hidden", "true");
			root.appendChild(cell);
		}

		for (let d = 1; d <= lastDay; d++) {
			const dayStr = iso(y, m0 + 1, d);
			const cell = document.createElement("button");
			cell.type = "button";
			cell.className = "club-cal__cell";
			cell.dataset.day = dayStr;
			cell.setAttribute(
				"aria-label",
				`${String(d)} · ${new Date(y, m0, d).toLocaleDateString("es-EC", { weekday: "long" })}`,
			);

			const num = document.createElement("span");
			num.className = "club-cal__num";
			num.textContent = String(d);
			num.setAttribute("aria-hidden", "true");
			cell.appendChild(num);

			const tipos = dayTipos.get(dayStr);
			if (tipos && tipos.size) {
				cell.classList.add("club-cal__cell--busy");
				const order = ["competicion", "examen", "evento", "club"];
				const sortedTipos = [...tipos].sort((a, b) => order.indexOf(a) - order.indexOf(b));
				for (const t of sortedTipos) {
					cell.classList.add(`club-cal__cell--tipo-${t}`);
				}

				const row = document.createElement("div");
				row.className = "club-cal__dots";
				row.setAttribute("aria-hidden", "true");
				row.appendChild(renderDots(sortedTipos));
				cell.appendChild(row);

				const strip = document.createElement("div");
				strip.className = "club-cal__tipo-strip";
				strip.setAttribute("aria-hidden", "true");
				for (const t of sortedTipos) {
					const seg = document.createElement("span");
					seg.className = `club-cal__tipo-seg club-cal__tipo-seg--${t}`;
					strip.appendChild(seg);
				}
				cell.appendChild(strip);
			}

			if (dayStr === todayStr) cell.classList.add("club-cal__cell--today");

			root.appendChild(cell);
		}
	}

	function renderYearGrid(root, dayTipos, year, todayStr, onPickMonth) {
		root.replaceChildren();
		for (let m0 = 0; m0 < 12; m0++) {
			const mini = document.createElement("button");
			mini.type = "button";
			mini.className = "club-cal__mini";
			mini.dataset.gotoMonth = `${year}-${pad(m0 + 1)}`;
			mini.setAttribute("aria-label", `Ver ${monthTitle(year, m0)}`);

			const tit = document.createElement("span");
			tit.className = "club-cal__mini-title";
			tit.textContent = shortMonth(m0).replace(/\.$/, "");
			mini.appendChild(tit);

			const grid = document.createElement("div");
			grid.className = "club-cal__mini-grid";

			const first = new Date(year, m0, 1);
			const off = (first.getDay() + 6) % 7;
			const lastDay = new Date(year, m0 + 1, 0).getDate();

			for (let i = 0; i < off; i++) {
				const c = document.createElement("span");
				c.className = "club-cal__mini-cell club-cal__mini-cell--pad";
				grid.appendChild(c);
			}
			let busyAny = false;
			for (let d = 1; d <= lastDay; d++) {
				const dayStr = iso(year, m0 + 1, d);
				const c = document.createElement("span");
				c.className = "club-cal__mini-cell";
				if (dayStr === todayStr) c.classList.add("club-cal__mini-cell--today");
				const tipos = dayTipos.get(dayStr);
				if (tipos && tipos.size) {
					busyAny = true;
					c.classList.add("club-cal__mini-cell--busy");
					for (const t of tipos) {
						const dot = document.createElement("i");
						dot.className = `club-cal__dot club-cal__dot--${t}`;
						c.appendChild(dot);
						break;
					}
				}
				grid.appendChild(c);
			}

			if (busyAny) mini.classList.add("club-cal__mini--has-events");

			mini.appendChild(grid);
			mini.addEventListener("click", () => onPickMonth(year, m0));
			root.appendChild(mini);
		}
	}

	function buildListItem(e) {
		const li = document.createElement("li");
		li.className = "cal-item";
		li.id = e.id;

		const dates = document.createElement("div");
		dates.className = "cal-item__dates";
		const time = document.createElement("time");
		time.dateTime = e.fechaInicio;
		time.textContent = formatRange(e);
		dates.appendChild(time);

		const body = document.createElement("div");
		body.className = "cal-item__body";

		const tag = document.createElement("span");
		tag.className = `cal-item__tag cal-item__tag--${e.tipo}`;
		tag.textContent = etiqueta(e.tipo);

		const h = document.createElement("h3");
		h.className = "cal-item__title";
		h.textContent = e.titulo;

		body.appendChild(tag);
		body.appendChild(h);
		if (e.descripcion) {
			const p = document.createElement("p");
			p.className = "cal-item__desc";
			p.textContent = e.descripcion;
			body.appendChild(p);
		}
		if (e.lugar) {
			const p = document.createElement("p");
			p.className = "cal-item__place";
			const strong = document.createElement("strong");
			strong.textContent = "Lugar:";
			p.appendChild(strong);
			p.appendChild(document.createTextNode(" " + e.lugar));
			body.appendChild(p);
		}

		li.appendChild(dates);
		li.appendChild(body);
		return li;
	}

	function renderList(listEl, emptyEl, entries, mode, y, m0) {
		listEl.replaceChildren();
		if (!entries.length) {
			emptyEl.classList.remove("is-hidden");
			return;
		}
		emptyEl.classList.add("is-hidden");
		if (mode === "month") {
			for (const e of entries) listEl.appendChild(buildListItem(e));
			return;
		}
		const byMonth = new Map();
		for (const e of entries) {
			const mk = e.fechaInicio.slice(0, 7);
			if (!byMonth.has(mk)) byMonth.set(mk, []);
			byMonth.get(mk).push(e);
		}
		const keys = [...byMonth.keys()].sort();
		for (const mk of keys) {
			const [yy, mm] = mk.split("-").map(Number);
			const sub = document.createElement("li");
			sub.className = "club-cal__month-block";

			const h = document.createElement("h3");
			h.className = "club-cal__month-block-title";
			h.textContent = monthTitle(yy, mm - 1);
			sub.appendChild(h);

			const ul = document.createElement("ul");
			ul.className = "cal-list club-cal__nested-list";
			for (const e of byMonth.get(mk)) {
				ul.appendChild(buildListItem(e));
			}
			sub.appendChild(ul);
			listEl.appendChild(sub);
		}
	}

	function run() {
		const root = document.querySelector("[data-club-cal]");
		if (!root || root.dataset.jgCalBound === "1") return;
		root.dataset.jgCalBound = "1";

		const tabMonth = root.querySelector('[data-cal-tab="month"]');
		const tabYear = root.querySelector('[data-cal-tab="year"]');
		const navMonth = root.querySelector("[data-cal-nav-month]");
		const navYear = root.querySelector("[data-cal-nav-year]");
		const panelMonth = root.querySelector("[data-cal-panel-month]");
		const panelYear = root.querySelector("[data-cal-panel-year]");
		const gridMonth = root.querySelector("[data-cal-month-grid]");
		const gridYear = root.querySelector("[data-cal-year-grid]");
		const hMonth = root.querySelector("[data-cal-month-heading]");
		const hYear = root.querySelector("[data-cal-year-heading]");
		const listEl = root.querySelector("[data-cal-list]");
		const emptyEl = root.querySelector("[data-cal-empty]");
		const titleEl = root.querySelector("[data-cal-list-title]");
		const subEl = root.querySelector("[data-cal-list-sub]");

		const dayTipos = buildDayTipos(items);
		const dayEventsMap = buildDayEvents(items);

		const daySheet = root.querySelector("[data-cal-day-sheet]");
		const daySheetDate = root.querySelector("[data-cal-day-sheet-date]");
		const daySheetList = root.querySelector("[data-cal-day-sheet-list]");
		const daySheetEmpty = root.querySelector("[data-cal-day-sheet-empty]");
		let pickedDayBtn = null;

		function hideDaySheet() {
			if (daySheet) daySheet.hidden = true;
			if (pickedDayBtn) {
				pickedDayBtn.classList.remove("club-cal__cell--picked");
				pickedDayBtn = null;
			}
		}

		function openDaySheet(dayStr) {
			if (!daySheet || !daySheetDate || !daySheetList || !daySheetEmpty) return;
			const evs = dayEventsMap.get(dayStr) || [];
			daySheet.hidden = false;
			daySheetDate.textContent = formatDayHeading(dayStr);
			daySheetList.replaceChildren();
			daySheet.scrollIntoView({ behavior: "smooth", block: "nearest" });
			if (!evs.length) {
				daySheetEmpty.hidden = false;
				return;
			}
			daySheetEmpty.hidden = true;
			for (const e of evs) {
				const li = document.createElement("li");
				li.className = "club-cal__day-sheet-item";

				const tag = document.createElement("span");
				tag.className = `cal-item__tag cal-item__tag--${e.tipo}`;
				tag.textContent = etiqueta(e.tipo);

				const h = document.createElement("p");
				h.className = "club-cal__day-sheet-title";
				h.textContent = e.titulo;

				li.appendChild(tag);
				li.appendChild(h);
				if (e.descripcion) {
					const p = document.createElement("p");
					p.className = "club-cal__day-sheet-desc";
					p.textContent = e.descripcion;
					li.appendChild(p);
				}
				if (e.lugar) {
					const p = document.createElement("p");
					p.className = "club-cal__day-sheet-place";
					const strong = document.createElement("strong");
					strong.textContent = "Lugar:";
					p.appendChild(strong);
					p.appendChild(document.createTextNode(" " + e.lugar));
					li.appendChild(p);
				}
				daySheetList.appendChild(li);
			}
		}

		gridMonth.addEventListener("click", (e) => {
			const btn = e.target.closest(".club-cal__cell[data-day]");
			if (!(btn instanceof HTMLButtonElement)) return;
			const dayStr = btn.dataset.day;
			if (!dayStr) return;
			if (pickedDayBtn && pickedDayBtn !== btn) pickedDayBtn.classList.remove("club-cal__cell--picked");
			pickedDayBtn = btn;
			btn.classList.add("club-cal__cell--picked");
			openDaySheet(dayStr);
		});
		const hashId = decodeURIComponent((location.hash || "").slice(1));
		const hashEv = hashId ? items.find((e) => e.id === hashId) : undefined;
		const init = hashEv
			? (() => {
					const [yy, mm] = hashEv.fechaInicio.split("-").map(Number);
					return { y: yy, m0: mm - 1 };
				})()
			: pickInitialMonth(items);
		let view = "month";
		let y = init.y;
		let m0 = init.m0;
		let yearShown = y;

		const today = new Date();
		const todayStr = iso(today.getFullYear(), today.getMonth() + 1, today.getDate());

		function sync() {
			hideDaySheet();
			if (view === "month") {
				tabMonth.setAttribute("aria-selected", "true");
				tabYear.setAttribute("aria-selected", "false");
				navMonth.hidden = false;
				navMonth.classList.remove("is-hidden");
				navYear.hidden = true;
				navYear.classList.add("is-hidden");
				panelMonth.hidden = false;
				panelMonth.classList.remove("is-hidden");
				panelYear.hidden = true;
				panelYear.classList.add("is-hidden");
				hMonth.textContent = monthTitle(y, m0);
				renderMonthGrid(gridMonth, dayTipos, y, m0, todayStr);
				const monthEvents = items
					.filter((e) => overlapsMonth(e, y, m0))
					.sort((a, b) => a.fechaInicio.localeCompare(b.fechaInicio));
				titleEl.textContent = "Eventos del mes";
				subEl.textContent = monthTitle(y, m0).replace(/^./, (c) => c.toUpperCase());
				renderList(listEl, emptyEl, monthEvents, "month", y, m0);
			} else {
				tabMonth.setAttribute("aria-selected", "false");
				tabYear.setAttribute("aria-selected", "true");
				navMonth.hidden = true;
				navMonth.classList.add("is-hidden");
				navYear.hidden = false;
				navYear.classList.remove("is-hidden");
				panelMonth.hidden = true;
				panelMonth.classList.add("is-hidden");
				panelYear.hidden = false;
				panelYear.classList.remove("is-hidden");
				hYear.textContent = String(yearShown);
				renderYearGrid(gridYear, dayTipos, yearShown, todayStr, (yy, mm) => {
					view = "month";
					y = yy;
					m0 = mm;
					sync();
				});
				const yearEvents = items
					.filter((e) => overlapsYear(e, yearShown))
					.sort((a, b) => a.fechaInicio.localeCompare(b.fechaInicio));
				titleEl.textContent = "Eventos del año";
				subEl.textContent = `${yearShown} · pulsa un mes en la cuadrícula para ver el detalle`;
				renderList(listEl, emptyEl, yearEvents, "year", yearShown, 0);
			}
		}

		tabMonth.addEventListener("click", () => {
			view = "month";
			sync();
		});
		tabYear.addEventListener("click", () => {
			view = "year";
			yearShown = y;
			sync();
		});

		root.querySelector("[data-cal-prev-month]").addEventListener("click", () => {
			m0--;
			if (m0 < 0) {
				m0 = 11;
				y--;
			}
			sync();
		});
		root.querySelector("[data-cal-next-month]").addEventListener("click", () => {
			m0++;
			if (m0 > 11) {
				m0 = 0;
				y++;
			}
			sync();
		});
		root.querySelector("[data-cal-today]").addEventListener("click", () => {
			const n = new Date();
			y = n.getFullYear();
			m0 = n.getMonth();
			sync();
		});

		root.querySelector("[data-cal-prev-year]").addEventListener("click", () => {
			yearShown--;
			sync();
		});
		root.querySelector("[data-cal-next-year]").addEventListener("click", () => {
			yearShown++;
			sync();
		});

		sync();

		if (hashId) {
			requestAnimationFrame(() => {
				const el = document.getElementById(hashId);
				if (el) el.scrollIntoView({ behavior: "smooth", block: "center" });
			});
		}
	}

	run();
	document.addEventListener("astro:page-load", run);
</script>

