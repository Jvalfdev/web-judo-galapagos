---
import { Image } from "astro:assets";
import fotoMaestro from "../../assets/maestro.jpg";
---

<section class="master" aria-labelledby="master-title">
	<div class="master__visual">
		<div class="master__glow" aria-hidden="true"></div>
		<div class="master__frame">
			<Image
				src={fotoMaestro}
				alt="Jose Andrés Ramos"
				class="master__photo"
				width={480}
				height={640}
				sizes="(min-width: 900px) 320px, min(72vw, 280px)"
				loading="lazy"
				decoding="async"
			/>
		</div>
	</div>
	<div class="master__content">
		<p class="master__eyebrow">Dirección técnica</p>
		<h2 id="master-title" class="master__title">Jose Andrés Ramos</h2>
	</div>
</section>

<style>
	.master {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-lg);
		padding: var(--space-2xl) clamp(1rem, 5vw, 4rem);
		border-top: 1px solid var(--border-subtle);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.02), transparent 45%);
		overflow: hidden;
		text-align: center;
	}

	.master__visual {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		max-width: 320px;
	}

	.master__frame {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 320px;
		aspect-ratio: 4 / 4.35;
		padding: 0;
		border-radius: var(--radius-lg);
		border: 1px solid var(--border-subtle);
		background: var(--master-frame-bg);
		overflow: hidden;
		box-sizing: border-box;
	}

	.master__photo {
		display: block;
		width: 100%;
		height: 108%;
		max-width: none;
		object-fit: cover;
		object-position: center 8%;
	}

	.master__glow {
		position: absolute;
		inset: -20%;
		background: radial-gradient(circle at 50% 50%, rgba(255, 51, 85, 0.2), transparent 58%);
		filter: blur(36px);
		opacity: 0.65;
		pointer-events: none;
	}

	.master__content {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 28rem;
	}

	.master__eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.055em;
		text-transform: uppercase;
		color: var(--ice);
		opacity: 0.9;
	}

	.master__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(1.75rem, 3.5vw, 2.65rem);
		line-height: 1.08;
		letter-spacing: -0.028em;
	}
</style>
