---
import { Image } from "astro:assets";
import logoClub from "../../assets/logo mas detallago.jpg";
---

<section class="master" aria-labelledby="master-title">
	<div class="master__visual">
		<div class="master__glow" aria-hidden="true"></div>
		<div class="master__frame">
			<Image
				src={logoClub}
				alt="Escudo — Club de Judo Galápagos"
				class="master__logo"
				width={480}
				height={480}
				sizes="(min-width: 900px) min(42vw, 360px), min(72vw, 280px)"
				loading="lazy"
				decoding="async"
			/>
		</div>
	</div>
	<div class="master__content">
		<p class="master__eyebrow">Dirección técnica</p>
		<h2 id="master-title" class="master__title">Jose Andres Ramos</h2>
		<p class="master__text">Titulaciones y experiencia de Jose</p>
		<span class="master__soon">Marcador de posición — página «El maestro»</span>
	</div>
</section>

<style>
	.master {
		position: relative;
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-lg);
		align-items: center;
		padding: var(--space-2xl) clamp(1rem, 5vw, 4rem);
		border-top: 1px solid var(--border-subtle);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.02), transparent 45%);
		overflow: hidden;
	}

	@media (min-width: 900px) {
		.master {
			grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
			gap: var(--space-xl);
		}
	}

	.master__visual {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 220px;
		border-radius: calc(var(--radius-lg) + 8px);
	}

	@media (min-width: 900px) {
		.master__visual {
			min-height: 320px;
		}
	}

	.master__frame {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		width: min(100%, 320px);
		margin-inline: auto;
		aspect-ratio: 1;
		padding: clamp(1rem, 4vw, 1.75rem);
		border-radius: inherit;
		border: 1px solid var(--border-subtle);
		background: var(--master-frame-bg);
		transform: rotate(-1.5deg);
		transition: transform 0.45s var(--ease-out-expo);
		box-sizing: border-box;
	}

	@media (min-width: 900px) {
		.master__frame {
			width: min(100%, 360px);
		}
	}

	.master:hover .master__frame {
		transform: rotate(0deg) scale(1.01);
	}

	.master__logo {
		display: block;
		width: 100%;
		height: auto;
		max-height: 100%;
		object-fit: contain;
	}

	.master__glow {
		position: absolute;
		inset: -20%;
		background: radial-gradient(circle at 50% 50%, rgba(255, 51, 85, 0.2), transparent 58%);
		filter: blur(36px);
		opacity: 0.65;
		pointer-events: none;
	}

	.master__content {
		position: relative;
		z-index: 1;
	}

	.master__eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.055em;
		text-transform: uppercase;
		color: var(--ice);
		opacity: 0.9;
	}

	.master__title {
		margin: 0 0 var(--space-sm);
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(1.75rem, 3.5vw, 2.65rem);
		line-height: 1.08;
		letter-spacing: -0.028em;
	}

	.master__text {
		margin: 0 0 var(--space-md);
		max-width: 42rem;
		font-size: 1.05rem;
		color: var(--text-muted);
		line-height: 1.65;
	}

	.master__soon {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.45rem 0.85rem;
		border-radius: var(--radius-full);
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--text-muted);
		border: 1px dashed var(--border-subtle);
		background: var(--toggle-bg);
	}

	.master__soon::before {
		content: "";
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 12px var(--accent-glow);
	}

	@media (prefers-reduced-motion: reduce) {
		.master__frame {
			transition: none;
		}

		.master:hover .master__frame {
			transform: rotate(-1.5deg);
		}
	}
</style>
