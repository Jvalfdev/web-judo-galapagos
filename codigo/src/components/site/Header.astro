---
import ThemeToggle from "./ThemeToggle.astro";
import logoClub from "../../assets/logoclubjudo.jpg";

const links = [
	{ href: "/quienes-somos", label: "Quiénes somos" },
	{ href: "/noticias", label: "Noticias" },
	{ href: "/calendario", label: "Calendario" },
	{ href: "/equipo-competicion", label: "Competición" },
	{ href: "/instalaciones", label: "Instalaciones" },
	{ href: "/promocion-cinturon", label: "Promoción" },
];
---

<header class="header">
	<a href="/" class="brand" aria-label="Inicio — Judo Galápagos">
		<img class="brand__logo" src={logoClub.src} alt="" width="36" height="36" decoding="async" />
		<span class="brand__stack">
			<span class="brand__text">Judo<span class="brand__accent">Galápagos</span></span>
			<span class="brand__tagline">Club federado</span>
		</span>
	</a>

	<nav class="nav nav--desktop" aria-label="Principal">
		<ul class="nav__list">
			{
				links.map((l) => (
					<li>
						<a href={l.href} class="nav__link">
							{l.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>

	<button
		type="button"
		class="nav-mobile-toggle"
		aria-expanded="false"
		aria-controls="nav-mobile-menu"
		aria-label="Abrir menú — todas las páginas del club"
		title="Menú — Noticias, calendario y más"
		data-nav-toggle
	>
		<span class="nav-mobile-toggle__bars" aria-hidden="true">
			<span></span>
			<span></span>
			<span></span>
		</span>
		<span class="nav-mobile-toggle__label">Menú</span>
	</button>

	<ThemeToggle />

	<div
		id="nav-mobile-menu"
		class="nav-mobile"
		aria-hidden="true"
		data-nav-mobile
	>
		<button type="button" class="nav-mobile__backdrop" data-nav-close aria-label="Cerrar menú">
			<span class="nav-mobile__backdrop-hit"></span>
		</button>
		<nav class="nav-mobile__panel" aria-label="Navegación móvil">
			<ul class="nav-mobile__list">
				<li>
					<a href="/" class="nav-mobile__link">Inicio</a>
				</li>
				{
					links.map((l) => (
						<li>
							<a href={l.href} class="nav-mobile__link">
								{l.label}
							</a>
						</li>
					))
				}
				<li>
					<a href="/#contacto" class="nav-mobile__link nav-mobile__link--accent">
						Contacto
					</a>
				</li>
			</ul>
		</nav>
	</div>
</header>

<style>
	.header {
		position: fixed;
		inset: 0 0 auto 0;
		z-index: 50;
		height: var(--header-h);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.65rem;
		padding: 0 clamp(1rem, 4vw, 3rem);
		background: var(--header-bg);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		border-bottom: 1px solid transparent;
		transition: border-color 0.35s var(--ease-out-expo), background 0.35s var(--ease-out-expo);
	}

	.header.is-scrolled {
		border-bottom-color: var(--border-subtle);
		background: var(--header-bg-scrolled);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.05rem;
		letter-spacing: -0.02em;
		min-width: 0;
	}

	.brand__stack {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		min-width: 0;
		line-height: 1.18;
	}

	.brand__text {
		display: block;
		min-width: 0;
		overflow-wrap: break-word;
		word-wrap: break-word;
		hyphens: manual;
	}

	.brand__tagline {
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--text-muted);
		overflow-wrap: break-word;
		min-width: 0;
		max-width: 100%;
	}

	.brand__logo {
		width: 36px;
		height: 36px;
		object-fit: contain;
		border-radius: 10px;
		flex-shrink: 0;
		box-shadow: 0 0 0 1px var(--border-subtle);
	}

	.brand__accent {
		color: var(--accent);
		margin-left: 2px;
	}

	.nav--desktop .nav__list {
		display: none;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 0.35rem;
	}

	@media (min-width: 880px) {
		.nav--desktop .nav__list {
			display: flex;
			align-items: center;
		}
	}

	.nav--desktop {
		flex: 1;
		display: flex;
		justify-content: center;
		min-width: 0;
	}

	@media (max-width: 879px) {
		.header {
			justify-content: flex-start;
			gap: 0.4rem;
		}

		.nav--desktop {
			display: none;
		}

		.brand {
			flex: 1 1 0;
			min-width: 0;
			max-width: 100%;
			margin-inline-end: auto;
			position: relative;
			z-index: 1;
		}

		.nav-mobile-toggle {
			margin-left: 0;
			flex-shrink: 0;
			position: relative;
			z-index: 2;
		}

		.brand__tagline {
			font-size: 0.58rem;
		}
	}

	.nav__link {
		display: inline-flex;
		padding: 0.45rem 0.85rem;
		border-radius: var(--radius-full);
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		transition:
			color 0.25s ease,
			background 0.25s ease;
	}

	.nav__link:hover {
		color: var(--text);
		background: var(--nav-link-hover-bg);
	}

	.nav-mobile-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.42rem;
		min-width: 5.5rem;
		min-height: 2.75rem;
		padding: 0.35rem 0.65rem 0.35rem 0.55rem;
		margin-left: auto;
		border: 1px solid rgba(225, 29, 72, 0.42);
		border-radius: 999px;
		background: linear-gradient(180deg, var(--toggle-bg), rgba(225, 29, 72, 0.06));
		box-shadow:
			0 1px 0 rgba(255, 255, 255, 0.06) inset,
			0 6px 22px -14px rgba(225, 29, 72, 0.55);
		cursor: pointer;
		color: var(--text);
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s var(--ease-out-expo);
	}

	.nav-mobile-toggle:hover {
		background: var(--toggle-bg-hover);
		border-color: rgba(225, 29, 72, 0.62);
		box-shadow:
			0 1px 0 rgba(255, 255, 255, 0.08) inset,
			0 10px 28px -16px var(--accent-glow);
	}

	.nav-mobile-toggle:active {
		transform: scale(0.98);
	}

	.nav-mobile-toggle:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.header.nav-is-open .nav-mobile-toggle {
		border-color: rgba(225, 29, 72, 0.55);
		background: var(--toggle-bg-hover);
	}

	.nav-mobile-toggle__label {
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--text);
		line-height: 1;
		white-space: nowrap;
	}

	@media (min-width: 880px) {
		.nav-mobile-toggle {
			display: none;
		}
	}

	.nav-mobile-toggle__bars {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 1.15rem;
		flex-shrink: 0;
	}

	.nav-mobile-toggle__bars span {
		display: block;
		height: 2px;
		border-radius: 1px;
		background: currentColor;
		transition:
			transform 0.3s var(--ease-out-expo),
			opacity 0.2s ease;
		transform-origin: center;
	}

	.header.nav-is-open .nav-mobile-toggle__bars span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.header.nav-is-open .nav-mobile-toggle__bars span:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}

	.header.nav-is-open .nav-mobile-toggle__bars span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* Panel móvil: por debajo del splash (100000) pero por encima del contenido */
	.nav-mobile {
		position: fixed;
		inset: var(--header-h) 0 0 0;
		z-index: 70;
		pointer-events: none;
		visibility: hidden;
	}

	.nav-mobile--open {
		pointer-events: auto;
		visibility: visible;
	}

	@media (min-width: 880px) {
		.nav-mobile {
			display: none !important;
		}
	}

	.nav-mobile__backdrop {
		position: absolute;
		inset: 0;
		padding: 0;
		border: none;
		background: transparent;
		cursor: pointer;
	}

	.nav-mobile__backdrop-hit {
		position: absolute;
		inset: 0;
		background: var(--nav-mobile-backdrop);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.nav-mobile--open .nav-mobile__backdrop-hit {
		opacity: 1;
	}

	.nav-mobile__panel {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		max-height: min(78vh, 520px);
		overflow-y: auto;
		padding: var(--space-md) clamp(1rem, 4vw, 2rem) var(--space-lg);
		background: var(--nav-mobile-panel-bg);
		border-bottom: 1px solid var(--border-subtle);
		box-shadow: var(--nav-mobile-panel-shadow);
		transform: translateY(-104%);
		transition: transform 0.38s var(--ease-out-expo);
		-webkit-overflow-scrolling: touch;
	}

	.nav-mobile--open .nav-mobile__panel {
		transform: translateY(0);
	}

	.nav-mobile__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.nav-mobile__link {
		display: block;
		padding: 0.85rem 1rem;
		border-radius: 12px;
		font-size: 1.05rem;
		font-weight: 600;
		text-decoration: none;
		color: var(--text);
		transition: background 0.2s ease;
	}

	.nav-mobile__link:hover {
		background: var(--nav-mobile-link-hover);
	}

	.nav-mobile__link--accent {
		margin-top: 0.35rem;
		text-align: center;
		color: var(--btn-on-accent);
		background: linear-gradient(135deg, var(--accent), #c9183a);
		box-shadow: 0 8px 28px -12px var(--accent-glow);
	}

	.nav-mobile__link--accent:hover {
		filter: brightness(1.06);
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-mobile__panel {
			transition-duration: 0.12s;
		}

		.nav-mobile-toggle__bars span {
			transition-duration: 0.12s;
		}
	}
</style>

<script>
	function navParts() {
		return {
			header: document.querySelector<HTMLElement>(".header"),
			toggle: document.querySelector<HTMLButtonElement>("[data-nav-toggle]"),
			menu: document.querySelector<HTMLElement>("[data-nav-mobile]"),
		};
	}

	function openMenu() {
		const { header, toggle, menu } = navParts();
		if (!header || !toggle || !menu) return;
		menu.classList.add("nav-mobile--open");
		menu.setAttribute("aria-hidden", "false");
		toggle.setAttribute("aria-expanded", "true");
		toggle.setAttribute("aria-label", "Cerrar menú de navegación");
		toggle.setAttribute("title", "Cerrar menú");
		const label = toggle.querySelector(".nav-mobile-toggle__label");
		if (label) label.textContent = "Cerrar";
		header.classList.add("nav-is-open");
		document.body.style.overflow = "hidden";
	}

	function closeMenu() {
		document.body.style.overflow = "";
		const { header, toggle, menu } = navParts();
		if (!menu || !header || !toggle) return;
		menu.classList.remove("nav-mobile--open");
		menu.setAttribute("aria-hidden", "true");
		toggle.setAttribute("aria-expanded", "false");
		toggle.setAttribute("aria-label", "Abrir menú — todas las páginas del club");
		toggle.setAttribute("title", "Menú — Noticias, calendario y más");
		const label = toggle.querySelector(".nav-mobile-toggle__label");
		if (label) label.textContent = "Menú";
		header.classList.remove("nav-is-open");
	}

	function toggleMenu() {
		const { menu } = navParts();
		if (!menu) return;
		if (menu.classList.contains("nav-mobile--open")) closeMenu();
		else openMenu();
	}

	document.addEventListener("click", (e: MouseEvent) => {
		const target = e.target as HTMLElement | null;
		if (!target) return;

		if (target.closest("[data-nav-toggle]")) {
			e.preventDefault();
			toggleMenu();
			return;
		}

		if (target.closest("[data-nav-close]")) {
			e.preventDefault();
			closeMenu();
			return;
		}

		if (target.closest("[data-nav-mobile] a")) {
			closeMenu();
		}
	});

	document.addEventListener("keydown", (ev: KeyboardEvent) => {
		if (ev.key !== "Escape") return;
		const { menu, toggle } = navParts();
		if (!menu?.classList.contains("nav-mobile--open")) return;
		closeMenu();
		toggle?.focus();
	});

	document.addEventListener("astro:before-swap", () => {
		document.body.style.overflow = "";
		closeMenu();
	});

	document.addEventListener("astro:page-load", () => {
		closeMenu();
		syncHeaderScrolled();
	});

	function syncHeaderScrolled() {
		document
			.querySelector(".header")
			?.classList.toggle("is-scrolled", window.scrollY > 24);
	}

	syncHeaderScrolled();
	window.addEventListener("scroll", syncHeaderScrolled, { passive: true });
</script>
