---
import {
	urlWhatsApp,
	telefonoHrefTel,
	telefonoTextoLegible,
} from "../../data/contacto";
import { Image } from "astro:assets";
import logoPie from "../../assets/logo mas detallago.jpg";

const waHref = urlWhatsApp();
const telHref = telefonoHrefTel();
const telLabel = telefonoTextoLegible();

const urlFacebook =
	"https://www.facebook.com/people/Escuela-de-Judo-y-Defensa-Personal-Gal%C3%A1pagos/100086158196604/";
const urlInstagram = "https://www.instagram.com/escuela_judo_galapagos/";
---

<footer id="contacto" class="footer">
	<div class="footer__grid">
		<div class="footer__brand">
			<Image
				src={logoPie}
				alt="Club de Judo Galápagos"
				class="footer__brand-img"
				sizes="(max-width: 480px) 160px, 200px"
				loading="lazy"
				decoding="async"
			/>
		</div>

		<div class="footer__block">
			<h3 class="footer__heading">Contacto</h3>
			<ul class="footer__list">
				<li>
					<a href={telHref}>{telLabel}</a>
				</li>
				<li>
					<div class="footer__social" role="group" aria-label="WhatsApp, Facebook e Instagram">
						<a
							href={waHref}
							class="footer__social-link footer__social-link--wa"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="WhatsApp del club"
						>
							<svg class="footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
								<path
									fill="currentColor"
									d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
								/>
							</svg>
						</a>
						<a
							href={urlFacebook}
							class="footer__social-link footer__social-link--fb"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Facebook — Escuela de Judo y Defensa Personal Galápagos"
						>
							<svg class="footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
								<path
									fill="currentColor"
									d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
								/>
							</svg>
						</a>
						<a
							href={urlInstagram}
							class="footer__social-link footer__social-link--ig"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Instagram — escuela_judo_galapagos"
						>
							<svg class="footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
								<path
									fill="currentColor"
									d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
								/>
							</svg>
						</a>
					</div>
				</li>
			</ul>
		</div>

		<div class="footer__block">
			<h3 class="footer__heading">Dojo</h3>
			<p class="footer__address">
				C. del Silo, 2<br />
				19174 Galápagos, Guadalajara
			</p>
		</div>

		<div class="footer__cta">
			<p class="footer__cta-label">Contacto</p>
			<a href={waHref} class="footer__cta-btn footer__cta-btn--wa" target="_blank" rel="noopener noreferrer">
				WhatsApp
			</a>
		</div>
	</div>

	<div class="footer__bar">
		<p class="footer__copy">© {new Date().getFullYear()} Club de Judo Galápagos</p>
		<a href="/#contenido-principal" class="footer__top">Volver arriba</a>
	</div>
</footer>

<style>
	.footer {
		padding: var(--space-2xl) clamp(1rem, 5vw, 4rem) var(--space-lg);
		border-top: 1px solid var(--border-subtle);
		background: var(--footer-bg);
	}

	.footer__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: var(--space-xl);
		align-items: start;
		padding-bottom: var(--space-xl);
		border-bottom: 1px solid var(--border-subtle);
	}

	.footer__brand-img {
		display: block;
		width: min(200px, 58vw);
		height: auto;
		margin-bottom: var(--space-sm);
		object-fit: contain;
		filter: drop-shadow(0 12px 36px rgba(0, 0, 0, 0.18));
	}

	.footer__heading {
		margin: 0 0 var(--space-sm);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.82rem;
		letter-spacing: 0.055em;
		text-transform: uppercase;
		color: var(--footer-text-soft);
	}

	.footer__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		font-weight: 500;
	}

	.footer__list a:not(.footer__social-link) {
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s ease, color 0.2s ease;
	}

	.footer__list a:not(.footer__social-link):hover {
		color: var(--accent);
		border-bottom-color: var(--footer-border-accent);
	}

	.footer__social {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.55rem;
		padding-top: 0.15rem;
	}

	.footer__social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.65rem;
		height: 2.65rem;
		border-radius: var(--radius-full);
		text-decoration: none;
		color: var(--text-body);
		background: rgba(0, 0, 0, 0.04);
		border: 1px solid var(--border-subtle);
		transition:
			color 0.2s ease,
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s var(--ease-out-expo);
	}

	[data-theme="dark"] .footer__social-link {
		background: rgba(255, 255, 255, 0.06);
	}

	.footer__social-link:hover {
		transform: translateY(-2px);
		border-color: var(--footer-border-accent);
	}

	.footer__social-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.footer__social-link--wa:hover {
		color: #fff;
		background: #25d366;
		border-color: rgba(255, 255, 255, 0.25);
	}

	.footer__social-link--fb:hover {
		color: #fff;
		background: #1877f2;
		border-color: rgba(255, 255, 255, 0.22);
	}

	.footer__social-link--ig:hover {
		color: #fff;
		background: linear-gradient(215deg, #f58529, #dd2a7b, #8134af);
		border-color: rgba(255, 255, 255, 0.22);
	}

	.footer__social-icon {
		width: 1.28rem;
		height: 1.28rem;
		display: block;
		flex-shrink: 0;
	}

	.footer__muted {
		color: var(--text-muted);
		font-size: 0.92rem;
	}

	.footer__address {
		margin: 0;
		font-style: normal;
		line-height: 1.55;
		color: var(--text-body);
	}

	.footer__cta {
		padding: var(--space-md);
		border-radius: var(--radius-lg);
		border: 1px solid var(--footer-cta-border);
		background: var(--footer-cta-bg);
		box-shadow: 0 24px 70px -40px var(--accent-glow);
	}

	.footer__cta-label {
		margin: 0 0 0.5rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.055em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.footer__cta-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.25rem;
		border-radius: var(--radius-full);
		font-weight: 700;
		text-decoration: none;
		color: var(--btn-on-accent);
		background: linear-gradient(135deg, var(--accent), #c9183a);
		border: 1px solid rgba(255, 255, 255, 0.14);
		transition:
			transform 0.25s var(--ease-out-expo),
			box-shadow 0.25s ease;
	}

	.footer__cta-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 14px 40px -16px var(--accent-glow);
	}

	.footer__cta-btn--wa {
		color: #fff;
		background: #25d366;
		border: 1px solid rgba(255, 255, 255, 0.22);
		box-shadow: 0 12px 40px -14px rgba(37, 211, 102, 0.55);
	}

	.footer__cta-btn--wa:hover {
		filter: brightness(1.06);
		box-shadow: 0 16px 48px -14px rgba(37, 211, 102, 0.65);
	}

	.footer__bar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		padding-top: var(--space-lg);
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	.footer__copy {
		margin: 0;
	}

	.footer__top {
		text-decoration: none;
		font-weight: 600;
		color: var(--footer-text-soft);
		transition: color 0.2s ease;
	}

	.footer__top:hover {
		color: var(--accent);
	}
</style>
