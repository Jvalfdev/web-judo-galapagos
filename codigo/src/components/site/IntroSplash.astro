---
/**
 * Coloca tu escudo en public/escudo-club.svg (o PNG y cambia logoSrc).
 */
interface Props {
	logoSrc?: string;
	logoAlt?: string;
}

const { logoSrc = "/escudo-club.svg", logoAlt = "Escudo — Club de Judo Galápagos" } = Astro.props;
---

<div
	id="intro-splash"
	class="intro-splash"
	role="dialog"
	aria-modal="true"
	aria-labelledby="intro-splash-title"
	aria-describedby="intro-splash-desc"
	data-intro-splash
>
	<span id="intro-splash-title" class="intro-splash__sr-only">Club de Judo Galápagos</span>
	<span id="intro-splash-desc" class="intro-splash__sr-only">Presentación del escudo del club</span>
	<button type="button" class="intro-splash__skip" data-intro-splash-skip>
		Saltar
	</button>
	<div class="intro-splash__inner">
		<img
			class="intro-splash__logo"
			src={logoSrc}
			alt={logoAlt}
			width="240"
			height="240"
			decoding="async"
			fetchpriority="high"
		/>
	</div>
</div>

<style is:global>
	.jg-no-splash .intro-splash {
		display: none !important;
	}

	body.jg-splash-active {
		overflow: hidden;
	}

	.intro-splash {
		position: fixed;
		inset: 0;
		z-index: 100000;
		display: grid;
		place-items: center;
		padding: 2rem;
		background: #050508;
		animation: intro-splash-outro 0.85s cubic-bezier(0.33, 1, 0.68, 1) forwards;
		animation-delay: 1.05s;
	}

	.intro-splash__inner {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
	}

	.intro-splash__logo {
		width: min(46vw, 240px);
		height: auto;
		object-fit: contain;
		filter: drop-shadow(0 12px 48px rgba(255, 51, 85, 0.35));
		animation: intro-splash-logo 1s cubic-bezier(0.33, 1, 0.68, 1) forwards;
	}

	.intro-splash__skip {
		position: absolute;
		top: clamp(1rem, 4vw, 1.75rem);
		right: clamp(1rem, 4vw, 1.75rem);
		z-index: 2;
		padding: 0.45rem 0.85rem;
		border-radius: 999px;
		font-family: var(--font-body, system-ui);
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: rgba(244, 244, 245, 0.72);
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.12);
		cursor: pointer;
		transition:
			color 0.2s ease,
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.intro-splash__skip:hover {
		color: #fff;
		background: rgba(255, 255, 255, 0.1);
		border-color: rgba(255, 255, 255, 0.18);
	}

	.intro-splash__sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.intro-splash.intro-splash--hurry .intro-splash__logo {
		animation: none;
		opacity: 1;
		transform: none;
		filter: none;
	}

	.intro-splash.intro-splash--hurry {
		animation: intro-splash-outro-fast 0.38s ease forwards;
		animation-delay: 0s;
	}

	@keyframes intro-splash-logo {
		0% {
			opacity: 0;
			transform: scale(0.88);
			filter: blur(14px);
		}
		55% {
			opacity: 1;
			transform: scale(1);
			filter: blur(0);
		}
		100% {
			opacity: 1;
			transform: scale(1);
			filter: blur(0);
		}
	}

	@keyframes intro-splash-outro {
		0% {
			opacity: 1;
		}
		100% {
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
		}
	}

	@keyframes intro-splash-outro-fast {
		0% {
			opacity: 1;
		}
		100% {
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.intro-splash__logo {
			animation: none;
			opacity: 1;
			transform: none;
			filter: drop-shadow(0 12px 48px rgba(255, 51, 85, 0.35));
		}

		.intro-splash {
			animation: intro-splash-outro-fast 0.35s ease forwards;
			animation-delay: 0.2s;
		}

		.intro-splash.intro-splash--hurry {
			animation-duration: 0.2s;
		}
	}
</style>

<script>
	import { initIntroSplash } from "../../scripts/introSplash";

	initIntroSplash();
	document.addEventListener("astro:page-load", initIntroSplash);
</script>
